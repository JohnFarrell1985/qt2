# ================================================================
# A股量化因子迭代平台 — 环境变量模板
# ================================================================
# 复制此文件为 .env 并填入实际值:  cp .env.example .env
# .env 已在 .gitignore 中, 不会提交到仓库
# 优先级: 系统环境变量 > .env > 代码默认值
# ================================================================

# ── 数据库 (PostgreSQL 16) ──────────────────────────────────────
DATABASE_URL=postgresql://用户名:密码@主机:5432/qt_quant
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=1800

# ── 迅投 QMT / MiniQMT ────────────────────────────────────────
QMT_MINI_PATH=
QMT_ACCOUNT_ID=
QMT_ACCOUNT_TYPE=STOCK

# ── API 服务 ────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8012
LOG_LEVEL=INFO

# ── Webhook (飞书/OpenClaw) ─────────────────────────────────────
OPENCLAW_WEBHOOK_URL=
FEISHU_WEBHOOK_URL=
FEISHU_APP_ID=
FEISHU_APP_SECRET=
