# Fin-R1 Live Data Middleware - 环境变量配置示例
# 复制此文件为 .env 并修改为你的实际配置

# ============================================
# 数据库配置（必填）
# ============================================
# PostgreSQL 连接 URL
# 格式: postgresql://用户名:密码@主机:端口/数据库名
DATABASE_URL=postgresql://game_agents:1234+asdf@123.60.11.74:5432/finr1_data

# ============================================
# GPU配置（如使用多GPU服务器）
# ============================================
# 指定使用哪个GPU（可选，默认使用所有GPU）
# 单GPU服务器: 设置为 0 或 all
# 多GPU服务器: 设置为 GPU编号，如 0, 1, 2, 3
# A800示例: 使用第2号GPU，设置为 2
GPU_DEVICE_ID=2

# ============================================
# vLLM 模型服务配置（必填）
# ============================================
# vLLM API 地址（通常是本地或内网地址）
VLLM_BASE_URL=http://172.17.0.1:8010

# 模型路径（vLLM中的模型标识）
VLLM_MODEL=/models/Fin-R1

# vLLM 请求超时时间（秒）
VLLM_TIMEOUT=120

# ============================================
# API 中间层服务配置（可选）
# ============================================
# 服务监听地址
HOST=0.0.0.0

# 服务端口号
PORT=8012

# 工作进程数（建议设置为 CPU 核心数）
WORKERS=1

# ============================================
# 数据源开关（可选）
# ============================================
# 是否启用实时API数据
ENABLE_REALTIME_API=true

# 是否启用数据库历史数据
ENABLE_DB_HISTORY=true

# 实时数据缓存时间（秒）
DATA_CACHE_TTL=60

# 最大返回股票数量
MAX_DATA_STOCKS=20

# ============================================
# 日志配置（可选）
# ============================================
# 日志级别: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# ============================================
# Web UI 配置（可选）
# ============================================
# Web UI 连接 API 中间层的地址
# - 内网访问模式: http://172.17.0.1:8012 (仅本机和容器访问)
# - 公网访问模式: http://<服务器公网IP>:8012 (允许外部直接调用API)
# 注意: 如果设置公网IP，请确保已配置防火墙规则限制访问
BASE_URL=http://172.17.0.1:8012

# ============================================
# 安全相关（生产环境建议设置）
# ============================================
# ⚠️ 重要提示: 如果8011和8012端口开放公网访问，请务必配置以下安全措施

# API 访问密钥（留空则不验证，生产环境强烈建议设置）
# 设置后，所有API请求都必须在Header中携带: X-API-Key: your-secret-key
# API_KEY=your-secret-key-here

# 允许的 CORS 源（逗号分隔，* 表示允许所有，生产环境建议限制域名）
# CORS_ORIGINS=http://localhost:8011,https://your-domain.com

# ============================================
# 公网访问安全建议
# ============================================
# 1. 配置防火墙限制IP白名单（UFW示例）:
#    ufw allow from 你的办公IP to any port 8011
#    ufw allow from 你的办公IP to any port 8012
#    ufw deny 8011
#    ufw deny 8012
#
# 2. 使用Nginx反向代理并启用HTTPS
#
# 3. 设置强密码的API_KEY并定期更换
#
# 4. 监控访问日志，及时发现异常请求
