# qt-quant 环境变量模板 (MA 程序选股 + QMT)
# 复制为 env/.env.db、.env.qmt 等分文件填入实际值
# 优先级: 系统环境变量 > env/.env.* > config/app.json + config/strategies/*.json

# ── env/.env.db ──
DATABASE_URL=postgresql://postgres:password@localhost:5432/qt_quant
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10

# ── env/.env.qmt ──
QMT_PATH=
QMT_ACCOUNT_ID=
QMT_ACCOUNT_TYPE=STOCK
DL_BATCH_SIZE=500
DL_START_1D=20160101

# ── env/.env.datacollect ──
TUSHARE_ENABLED=false
TUSHARE_TOKEN=
DATACOLLECT_AKSHARE_RATE=0.15
DATACOLLECT_MAX_RETRIES=5
DATACOLLECT_REQUEST_TIMEOUT=30

# ── env/.env.trading ──
TRADING_PAPER_MODE=true
RISK_STOP_LOSS_PCT=-8.0
RISK_MAX_SINGLE_POSITION_PCT=30.0
BACKTEST_INITIAL_CAPITAL=1000000
SCHEDULER_DAILY_SYNC_TIME=16:30
LOG_LEVEL=INFO

# ── 选股 (可选, 默认见 config/app.json + config/strategies/) ──
# SELECTION_STRATEGY=bull_launch
# SELECTION_OUTPUT_DIR=reports
