# ================================================================
# A股量化因子迭代平台 — 环境变量模板
# ================================================================
# 复制此文件为 .env 并填入实际值:  cp .env.example .env
# .env 已在 .gitignore 中, 不会提交到仓库
# 优先级: 系统环境变量 > .env > 代码默认值
# ================================================================

# ────────────────────────────────────────────────────────────────
# 数据库 (PostgreSQL 16)
# ────────────────────────────────────────────────────────────────

# PostgreSQL 连接字符串
# 格式: postgresql://用户名:密码@主机:端口/数据库名
# 不填则使用代码默认值: postgresql://localhost:5432/qt_quant
DATABASE_URL=postgresql://localhost:5432/qt_quant

# SQLAlchemy 连接池常驻连接数
DB_POOL_SIZE=5

# 连接池允许的溢出连接数 (峰值临时创建, 空闲后释放)
DB_MAX_OVERFLOW=10

# 从连接池获取连接时的最大等待秒数
DB_POOL_TIMEOUT=30

# 连接在池中的最大存活秒数, 超过自动回收并重建
# 建议 < PG 的 idle_session_timeout, 一般 1800 (30分钟)
DB_POOL_RECYCLE=1800

# 启动时数据库连接重试次数
DB_INIT_MAX_RETRIES=5

# 启动重试退避基数 (秒, 指数退避)
DB_INIT_BACKOFF_BASE_SEC=2

# ────────────────────────────────────────────────────────────────
# 迅投 QMT (标准终端 / MiniQMT 极简版均适用)
# ────────────────────────────────────────────────────────────────

# QMT 安装目录下的 userdata_mini 路径 (标准 QMT 和 MiniQMT 都有此目录)
# xtquant 通过此路径与已登录的 QMT 终端通信
# 使用前请先手动登录 QMT 终端 (行情+交易 模式)
QMT_PATH=

# QMT 交易账户 ID (资金账号, 非登录用户名, 各券商位数不同)
# 华泰证券为 12 位, 登录 QMT 后在 "账户信息" 中查看
QMT_ACCOUNT_ID=

# QMT 交易账户类型: STOCK(股票) / CREDIT(信用) / FUTURE(期货)
QMT_ACCOUNT_TYPE=STOCK

# ────────────────────────────────────────────────────────────────
# 数据下载引擎 (DownloadEngine)
# ────────────────────────────────────────────────────────────────

# 每批下载的股票数量 (社区经验: 500 最稳定)
DL_BATCH_SIZE=500

# 两批之间的暂停秒数 (防限流, 建议 2.0~3.0)
DL_BATCH_PAUSE=2.0

# 单批下载失败时的最大重试次数
DL_RETRY_COUNT=3

# 首次重试的等待基数 (秒, 指数退避)
DL_RETRY_DELAY=5.0

# 单批下载的超时秒数
DL_TIMEOUT=600

# 各周期默认下载起始日期 (yyyymmdd)
DL_START_1D=20160101
DL_START_1W=20160101
DL_START_5M=20230101
DL_START_15M=20230101
DL_START_30M=20230101
DL_START_1H=20230101
DL_START_1M=20250101
DL_START_TICK=20260301

# ────────────────────────────────────────────────────────────────
# API 服务 (FastAPI + Uvicorn)
# ────────────────────────────────────────────────────────────────

# API 监听地址 (0.0.0.0=全部网卡, 127.0.0.1=仅本机)
API_HOST=0.0.0.0

# API 监听端口 (Swagger: http://localhost:8012/docs)
API_PORT=8012

# Uvicorn worker 进程数
UVICORN_WORKERS=2

# API Key 认证 (生产环境建议开启)
# 设为 true 后, 所有非公开端点需在 Header 带 X-API-Key
API_KEY_ENABLED=false
API_KEY=

# CORS 允许的源 (逗号分隔, 生产环境替换为实际域名)
# 例: http://localhost:3000,https://app.example.com
CORS_ORIGINS=*

# ────────────────────────────────────────────────────────────────
# 定时任务调度器
# ────────────────────────────────────────────────────────────────

# 每日数据同步执行时间 (HH:MM)
SCHEDULER_DAILY_SYNC_TIME=17:00

# 持仓快照执行时间 (HH:MM)
SCHEDULER_SNAPSHOT_TIME=15:30

# 模型重训周期 (周)
SCHEDULER_RETRAIN_WEEKS=4

# 每日同步回溯天数
SCHEDULER_DAILY_SYNC_DAYS_BACK=5

# 调度器轮询间隔 (秒)
SCHEDULER_POLL_INTERVAL_SEC=30

# ────────────────────────────────────────────────────────────────
# 日志
# ────────────────────────────────────────────────────────────────

# 全局日志级别: DEBUG / INFO / WARNING / ERROR / CRITICAL
LOG_LEVEL=INFO

# ────────────────────────────────────────────────────────────────
# 机器学习 (LightGBM 因子选股模型)
# ────────────────────────────────────────────────────────────────

# 模型文件存储目录
ML_MODEL_DIR=./models

# 预测标签的持有天数 (散户 T+1: 2=隔日卖, 5=周度, 20=月度)
ML_LABEL_PERIOD=2

# 训练窗口长度 (交易日数, 252≈1年)
ML_TRAIN_WINDOW=252

# 滚动重训步长 (交易日数, 21≈每月)
ML_RETRAIN_STEP=21

# ── 自动迭代引擎 ──

ML_ITERATE_MAX_ITERATIONS=50
ML_ITERATE_TARGET_SHARPE=2.0
ML_ITERATE_CONVERGENCE_PATIENCE=10
ML_ITERATE_INITIAL_TOP_N=30
ML_ITERATE_MIN_FACTORS=5

# ── 交叉验证 ──

ML_CV_N_SPLITS=5
ML_CV_PURGE_DAYS=3
ML_CV_EMBARGO_PCT=0.05

# ── 因子管线 ──

FACTOR_ALPHA158_ENABLED=true
FACTOR_ALPHA158_WINDOWS=5,10,20,30,60
FACTOR_XT_ENABLED=false
FACTOR_XT_CATEGORIES=factor_growth,factor_base_derivative,factor_metrics,factor_quality,factor_momentum,factor_risk
FACTOR_SCREEN_IC_THRESHOLD=0.03
FACTOR_SCREEN_ICIR_THRESHOLD=0.3
FACTOR_SCREEN_IC_POSITIVE_RATIO=0.55
FACTOR_SCREEN_CORR_THRESHOLD=0.7
FACTOR_SCREEN_DECAY_HALFLIFE_MIN=20

# ── 因子/模型监控 ──

FACTOR_MON_IC_WARNING=0.02
FACTOR_MON_ICIR_WARNING=0.5
FACTOR_MON_PSI_WARNING=0.2
FACTOR_MON_PSI_CRITICAL=0.4
FACTOR_MON_IC_WINDOW=20
MODEL_MON_CORR_WARNING=0.1
MODEL_MON_PSI_WARNING=0.2
MODEL_MON_CHECK_WINDOW=20

# ── 知识蒸馏 & 数据飞轮 ──

DISTILL_ENABLED=false
DISTILL_TEACHER_A=deepseek
DISTILL_TEACHER_B=qwen
DISTILL_JUDGE_MODEL=deepseek-r1
DISTILL_CONSENSUS_THRESHOLD=0.7
DISTILL_STUDENT_MODEL=finbert2-base
DISTILL_LORA_RANK=16
DISTILL_LORA_ALPHA=32
DISTILL_USE_ONNX=true
DISTILL_INT8=false
DISTILL_FLYWHEEL_SCHEDULE=weekly
DISTILL_FLYWHEEL_LOW_CONF_THRESHOLD=0.7
DISTILL_MODEL_PATH=models/distilled/

# ────────────────────────────────────────────────────────────────
# Signal 默认值
# 各策略未显式指定时使用的全局默认值
# ────────────────────────────────────────────────────────────────

# 全局默认止损 (%), 策略可单独覆盖
SIG_STOP_LOSS_PCT=-8.0

# 全局默认止盈 (%)
SIG_TAKE_PROFIT_PCT=15.0

# 全局默认最大持仓天数
SIG_MAX_HOLD_DAYS=10

# 全局默认移动止损回撤 (%, 0=不启用)
SIG_TRAILING_STOP_PCT=0.0

# 全局默认最低日成交额要求 (万元)
SIG_MIN_AMOUNT=5000.0

# ────────────────────────────────────────────────────────────────
# 持仓监控 (PositionMonitor)
# 散户实战止损止盈参数
# ────────────────────────────────────────────────────────────────

# 硬止损比例 (%, A股散户建议 -5~-8)
PM_STOP_LOSS_PCT=-8.0

# 止盈比例 (%, 与止损形成 ≥1.5:1 盈亏比)
PM_TAKE_PROFIT_PCT=15.0

# 移动止损: 从最高价回撤比例 (%)
PM_TRAILING_STOP_PCT=5.0

# 最大持仓天数 (超期+未盈利触发清仓)
PM_MAX_HOLD_DAYS=10

# 是否启用移动止损
PM_ENABLE_TRAILING_STOP=true

# 超期是否强制卖出
PM_FORCE_SELL_EXPIRY=true

# 是否启用分批止盈 (true=止盈时只卖一部分)
PM_PARTIAL_TAKE_PROFIT=false

# 分批止盈卖出比例 (0~1, 0.5=卖出一半)
PM_PARTIAL_TP_RATIO=0.5

# 超期清仓盈利阈值 (%, 超期且盈利<=此值才卖)
# 0.0=超期且未盈利就卖; 设 5.0=超期且盈利<5%才卖
PM_EXPIRY_LOSS_THRESHOLD=0.0

# ────────────────────────────────────────────────────────────────
# 信号仲裁 (SignalArbiter)
# ────────────────────────────────────────────────────────────────

# 最大同时持仓数 (散户 3~5 只)
ARB_MAX_HOLDINGS=5

# 每日最多买入几只新股
ARB_MAX_BUY_PER_DAY=2

# 每日最多卖出几只
ARB_MAX_SELL_PER_DAY=5

# 最低日成交额要求 (万元)
ARB_MIN_AMOUNT_WAN=5000.0

# 多策略共同看好加分系数
ARB_MULTI_BONUS=0.2
ARB_MAX_DAILY_TURNOVER_PCT=0.20

# ────────────────────────────────────────────────────────────────
# 仓位分配 (PositionSizer)
# ────────────────────────────────────────────────────────────────

# 分配模式: equal(等权) / atr(波动率反比) / kelly(凯利公式)
SIZER_MODE=equal

# 单票最大仓位占比 (%)
SIZER_MAX_SINGLE_PCT=20.0

# 总仓位上限 (%, 受宏观 multiplier 影响)
SIZER_MAX_TOTAL_PCT=80.0

# 最小交易金额 (元, 低于不值得交易)
SIZER_MIN_TRADE_AMOUNT=5000.0

# A股最小交易单位 (股, 100=一手)
SIZER_LOT_SIZE=100
SIZER_ATR_LOOKBACK=14
SIZER_KELLY_FRACTION=0.25
SIZER_DRAWDOWN_GUARD_ENABLED=true

# ────────────────────────────────────────────────────────────────
# 交易费率 — A 股
# ────────────────────────────────────────────────────────────────

# 佣金比例 (万1.15 = 0.000115, 根据券商协商调整)
FEE_COMMISSION_RATE=0.000115

# 单笔最低佣金 (元)
FEE_COMMISSION_MIN=5.0

# 印花税率 (千0.5 = 0.0005, 仅卖出, 2023.08.28 起)
FEE_STAMP_TAX_RATE=0.0005

# 过户费率 (万0.2 = 0.00002, 双向, 仅沪市)
FEE_TRANSFER_FEE_RATE=0.00002

# ────────────────────────────────────────────────────────────────
# 交易费率 — 港股通
# ────────────────────────────────────────────────────────────────

# 佣金比例 (万三)
FEE_HK_COMMISSION_RATE=0.0003

# 单笔最低佣金 (港元)
FEE_HK_COMMISSION_MIN=5.0

# 印花税率 (千一, 双向, 向上取整到港元)
FEE_HK_STAMP_TAX_RATE=0.001

# 交易费 (联交所)
FEE_HK_TRADING_FEE_RATE=0.0000565

# 交易征费 (证监会)
FEE_HK_TRANSACTION_LEVY_RATE=0.000027

# 会财局征费
FEE_HK_FRC_LEVY_RATE=0.0000015

# 股份交收费
FEE_HK_SETTLEMENT_FEE_RATE=0.000042

# 交收费最低 (港元)
FEE_HK_SETTLEMENT_FEE_MIN=2.0

# ────────────────────────────────────────────────────────────────
# 回测引擎
# ────────────────────────────────────────────────────────────────

# 初始资金 (元)
BACKTEST_INITIAL_CAPITAL=1000000

# 单只股票最大仓位占比 (0~1)
BACKTEST_MAX_POSITION_PCT=0.20

# 总仓位上限 (0~1)
BACKTEST_MAX_TOTAL_POSITION_PCT=0.80

# 最大同时持仓股票数
BACKTEST_MAX_HOLDINGS=5

# ── 滑点模型 ──

SLIPPAGE_ENABLED=false
SLIPPAGE_FIXED_BPS=5.0
SLIPPAGE_IMPACT_COEFF=0.1
SLIPPAGE_VOL_LOOKBACK=20
SLIPPAGE_ASYMMETRIC=true

# ── 市场状态门控 ──

REGIME_GATE_ENABLED=false
REGIME_GATE_DRIFT_WINDOW=63
REGIME_GATE_DRIFT_THRESHOLD=0.60
REGIME_GATE_VOL_WINDOW=252
REGIME_GATE_VOL_HIGH_PCT=0.80

# ── 组合优化 ──

PORTFOLIO_OPTIMIZER_METHOD=caa
PORTFOLIO_CAA_TARGET_VOL=0.10
PORTFOLIO_CAA_CAP=0.25
PORTFOLIO_CAA_CASH_ASSETS=["511010.SH", "511260.SH"]
PORTFOLIO_MAX_INDUSTRY_PCT=0.15
PORTFOLIO_MAX_SINGLE_PCT=0.05

# ── 数据质量 ──

DATA_QUALITY_ENABLED=true
DATA_QUALITY_Z_THRESHOLD=10.0
DATA_QUALITY_MAX_PCT_CHANGE=22.0

# ── 系统容错 ──

RESILIENCE_CB_THRESHOLD=5
RESILIENCE_RECOVERY_TIMEOUT=60.0
RESILIENCE_DEGRADATION_ENABLED=true

# ────────────────────────────────────────────────────────────────
# 交易 & 风控
# ────────────────────────────────────────────────────────────────

# 是否为模拟盘模式 (true=纸上交易, false=实盘)
TRADING_PAPER_MODE=true

# 个股止损线 (%)
RISK_STOP_LOSS_PCT=-8.0

# 个股止盈线 (%)
RISK_TAKE_PROFIT_PCT=20.0

# 单只股票最大持仓占比 (%, 实盘风控)
RISK_MAX_SINGLE_POSITION_PCT=30.0

# 总仓位上限 (%, 实盘风控)
RISK_MAX_TOTAL_POSITION_PCT=80.0

# 每日最大亏损限额 (%, 触发后暂停交易)
RISK_MAX_DAILY_LOSS_PCT=-5.0

# ════════════════════════════════════════════════════════════════
# 情绪引擎
# ════════════════════════════════════════════════════════════════

SENTIMENT_ENABLED=true
SENTIMENT_AUTO_APPLY=false
SENTIMENT_COLLECT_SCHEDULE=09:00,12:00,15:30,20:00
SENTIMENT_W_EARNING=0.25
SENTIMENT_W_CAPITAL=0.25
SENTIMENT_W_VOLATILITY=0.15
SENTIMENT_W_SECTOR=0.10
SENTIMENT_W_NEWS=0.15
SENTIMENT_W_GLOBAL=0.10
SENTIMENT_W_NORTHBOUND=0.0

# ════════════════════════════════════════════════════════════════
# ETF 轮动策略
# ════════════════════════════════════════════════════════════════

ETF_ROTATION_ENABLED=true
ETF_ROTATION_MOMENTUM_METHOD=13612w
ETF_ROTATION_LOOKBACK_DAYS=25
ETF_ROTATION_TOP_K=2
ETF_ROTATION_REBALANCE_INTERVAL=20
ETF_ROTATION_MIN_HOLD_DAYS=9
ETF_ROTATION_RANK_THRESHOLD=0.10
ETF_ROTATION_SCORE_MIN=0.0
ETF_ROTATION_SCORE_MAX=5.0
ETF_ROTATION_STOP_LOSS_DAILY=0.05
ETF_ROTATION_STOP_LOSS_3D=0.08
ETF_ROTATION_USE_CAA_WEIGHTS=false
ETF_ROTATION_CAA_TARGET_VOL=0.10
ETF_ROTATION_VOLATILITY_GATE=true
ETF_ROTATION_RISK_POOL=["510300.SH","159915.SZ","510500.SH","510880.SH","513180.SH","513100.SH","513500.SH","513880.SH","513030.SH","518880.SH","159985.SZ"]
ETF_ROTATION_DEFENSIVE_POOL=["511260.SH","511010.SH"]
ETF_ROTATION_CANARY_POOL=["513100.SH","511260.SH"]

# ════════════════════════════════════════════════════════════════
# 策略参数 — Tier 1 规则策略
# ════════════════════════════════════════════════════════════════

# ── 动量策略 (momentum) ──

STRAT_MOM_LOOKBACK=20
STRAT_MOM_TOP_N=10
STRAT_MOM_MIN_TURNOVER=0.5
STRAT_MOM_STOP_LOSS=-8.0
STRAT_MOM_TAKE_PROFIT=15.0
STRAT_MOM_MAX_HOLD_DAYS=5
STRAT_MOM_TRAILING_STOP=5.0

# ── 反转策略 (reversal) ──

STRAT_REV_LOOKBACK=10
STRAT_REV_TOP_N=10
STRAT_REV_MAX_DRAWDOWN=-30.0
STRAT_REV_STOP_LOSS=-5.0
STRAT_REV_TAKE_PROFIT=10.0
STRAT_REV_MAX_HOLD_DAYS=5
STRAT_REV_TRAILING_STOP=3.0
STRAT_REV_BOUNCE_TARGET=5.0

# ── 行业轮动策略 (industry_rotation) ──

STRAT_IND_LOOKBACK=20
STRAT_IND_TOP_INDUSTRIES=3
STRAT_IND_STOCKS_PER_IND=3
STRAT_IND_STOP_LOSS=-8.0
STRAT_IND_TAKE_PROFIT=15.0
STRAT_IND_MAX_HOLD_DAYS=10
STRAT_IND_TRAILING_STOP=5.0

# ── 均线突破策略 (moving_average) ──

STRAT_MA_SHORT=5
STRAT_MA_LONG=20
STRAT_MA_TOP_N=15
STRAT_MA_STOP_LOSS=-6.0
STRAT_MA_TAKE_PROFIT=12.0
STRAT_MA_MAX_HOLD_DAYS=10
STRAT_MA_TRAILING_STOP=4.0

# ── T+1 宽网格策略 (grid_trading) ──

STRAT_GRID_PCT=10.0
STRAT_GRID_LOOKBACK=60
STRAT_GRID_TOP_N=10
STRAT_GRID_STOP_LOSS=-5.0
STRAT_GRID_TAKE_PROFIT=6.0
STRAT_GRID_MAX_HOLD_DAYS=5

# ── 双低可转债策略 (cb_dual_low) ──

STRAT_CB_PRICE_WEIGHT=1.0
STRAT_CB_PREMIUM_WEIGHT=1.0
STRAT_CB_MAX_PRICE=130.0
STRAT_CB_MAX_PREMIUM=50.0
STRAT_CB_MIN_RATING=AA-
STRAT_CB_TOP_N=20
STRAT_CB_STOP_LOSS=-3.0
STRAT_CB_TAKE_PROFIT=10.0
STRAT_CB_MAX_HOLD_DAYS=20
STRAT_CB_MIN_AMOUNT=1000.0

# ── 低波红利策略 (low_vol_dividend) ──

STRAT_LV_LOOKBACK=60
STRAT_LV_VOL_WEIGHT=0.5
STRAT_LV_DIV_WEIGHT=0.5
STRAT_LV_MAX_VOL_PCT=40.0
STRAT_LV_MIN_DIV_YIELD=2.0
STRAT_LV_TOP_N=15
STRAT_LV_STOP_LOSS=-5.0
STRAT_LV_TAKE_PROFIT=10.0
STRAT_LV_MAX_HOLD_DAYS=20
STRAT_LV_TRAILING_STOP=3.0

# ════════════════════════════════════════════════════════════════
# 策略参数 — Tier 2 打分策略
# ════════════════════════════════════════════════════════════════

STRAT_SCORE_IC_WINDOW=20
STRAT_SCORE_TOP_N=20
STRAT_SCORE_NEUTRALIZE=false
STRAT_SCORE_STOP_LOSS=-8.0
STRAT_SCORE_TAKE_PROFIT=15.0
STRAT_SCORE_MAX_HOLD_DAYS=10
STRAT_SCORE_TRAILING_STOP=5.0

# ════════════════════════════════════════════════════════════════
# 策略参数 — Tier 3 ML 策略
# ════════════════════════════════════════════════════════════════

STRAT_ML_TOP_N=10
STRAT_ML_LONG_THRESHOLD=0.0
STRAT_ML_STOP_LOSS=-8.0
STRAT_ML_TAKE_PROFIT=15.0
STRAT_ML_MAX_HOLD_DAYS=8
STRAT_ML_TRAILING_STOP=5.0

# ════════════════════════════════════════════════════════════════
# 数据采集 (datacollect) — 限流 / 重试 / 代理
# ════════════════════════════════════════════════════════════════

DATACOLLECT_AKSHARE_RATE=0.15
DATACOLLECT_AKSHARE_BURST=3
DATACOLLECT_BAOSTOCK_RATE=5.0
DATACOLLECT_BAOSTOCK_BURST=10
TUSHARE_TOKEN=
DATACOLLECT_TUSHARE_RATE=0.8
DATACOLLECT_TUSHARE_BURST=5
DATACOLLECT_ADATA_RATE=0.5
DATACOLLECT_ADATA_BURST=5
DATACOLLECT_PYTDX_RATE=1.0
DATACOLLECT_PYTDX_BURST=5
DATACOLLECT_EASTMONEY_RATE=0.1
DATACOLLECT_EASTMONEY_BURST=2
DATACOLLECT_MAX_RETRIES=5
DATACOLLECT_RETRY_BACKOFF=2.0
DATACOLLECT_REQUEST_TIMEOUT=30
DATACOLLECT_IMPERSONATE=chrome
DATACOLLECT_PROXY_URL=
DATACOLLECT_ARCHIVE_DAYS=90
DATACOLLECT_GLOBAL_CONCURRENCY=50
DATACOLLECT_WRITE_BUFFER_SIZE=200
DATACOLLECT_WRITE_FLUSH_INTERVAL=1.0
DATACOLLECT_WRITE_BATCH_SIZE=5000
DATACOLLECT_CHUNK_THRESHOLD=100000
DATACOLLECT_PROXY_ENABLED=false
DATACOLLECT_PROXY_URLS=
DATACOLLECT_PROXY_ROTATE_STRATEGY=round_robin
DATACOLLECT_PROXY_HEALTH_CHECK_INTERVAL=300
DATACOLLECT_PROXY_BLACKLIST_COOLDOWN=600
DATACOLLECT_YFINANCE_RATE=0.5
DATACOLLECT_YFINANCE_BURST=10
DATACOLLECT_SINA_RATE=0.2
DATACOLLECT_SINA_BURST=3
DATACOLLECT_RSS_RATE=1.0
DATACOLLECT_RSS_BURST=5

# ── 熔断器 ──
DATACOLLECT_CB_FAILURE_THRESHOLD=5
DATACOLLECT_CB_COOLDOWN_SEC=300.0
DATACOLLECT_CB_SUCCESS_THRESHOLD=2

# ── 死信队列 ──
DATACOLLECT_DL_BACKOFF_BASE=60.0
DATACOLLECT_DL_MAX_RETRIES=3
DATACOLLECT_DL_PENDING_LIMIT=100

# ── 反爬哨兵 ──
DATACOLLECT_SENTINEL_LATENCY_SPIKE_SEC=10.0
DATACOLLECT_SENTINEL_LATENCY_WARN_SEC=5.0
DATACOLLECT_SENTINEL_SOFT_BLOCK_MIN_BYTES=50
DATACOLLECT_SENTINEL_CONSECUTIVE_TIMEOUT=2
DATACOLLECT_SENTINEL_HISTORY_SIZE=50

# ── 数据质量校验 ──
DATACOLLECT_VALIDATOR_PCT_CHANGE_LIMIT=22.0
DATACOLLECT_VALIDATOR_ZSCORE_LIMIT=10.0

# ── 幂等性 ──
DATACOLLECT_IDEMPOTENCY_TTL_HOURS=24

# ── RSS 新闻采集 ──
DATACOLLECT_RSSHUB_BASE_URL=https://rsshub.app
DATACOLLECT_RSS_MAX_ENTRIES=50
DATACOLLECT_RSS_SUMMARY_MAX_CHARS=500

# ════════════════════════════════════════════════════════════════
# 数据清洗 LLM (dataclean)
# ════════════════════════════════════════════════════════════════

LLM_PROVIDER=deepseek
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_REASONER_MODEL=deepseek-reasoner
QWEN_API_KEY=
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen3-max
LLM_TEMPERATURE=0.1
LLM_MAX_RETRIES=2
LLM_TIMEOUT=30

# ────────────────────────────────────────────────────────────────
# OpenClaw / 飞书 Webhook (事件推送)
# ────────────────────────────────────────────────────────────────

OPENCLAW_WEBHOOK_URL=
FEISHU_WEBHOOK_URL=
FEISHU_APP_ID=
FEISHU_APP_SECRET=

# Webhook HTTP 超时与连接池
WEBHOOK_HTTP_CONNECT_TIMEOUT=5.0
WEBHOOK_HTTP_READ_TIMEOUT=10.0
WEBHOOK_HTTP_MAX_CONNECTIONS=10
WEBHOOK_PUSH_MAX_RETRIES=2
