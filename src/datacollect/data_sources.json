{
  "sources": {
    "xtquant": {
      "display_name": "迅投QMT (xtquant)",
      "priority": 1,
      "collector_class": null,
      "package": "xtquant",
      "needs_token": false,
      "rate_domain": "xtquant",
      "rate": 2.0,
      "burst": 10,
      "max_concurrent": 50,
      "capabilities": ["stock_list", "daily_kline", "minute_kline", "index_daily", "financial", "etf", "cb", "realtime", "tick"],
      "history_depth_years": 10,
      "supports_realtime": true,
      "note": "需要QMT终端运行, CI环境不可用"
    },
    "baostock": {
      "display_name": "BaoStock (证券宝)",
      "priority": 2,
      "collector_class": "src.datacollect.collectors.baostock_collector.BaostockCollector",
      "package": "baostock",
      "needs_token": false,
      "rate_domain": "baostock",
      "rate": 5.0,
      "burst": 10,
      "max_concurrent": 3,
      "capabilities": ["stock_list", "daily_kline", "minute_kline", "index_daily", "financial"],
      "history_depth_years": 35,
      "supports_realtime": false,
      "note": "免费无限流, 历史数据回溯到1990年, 财务数据2007年起"
    },
    "akshare": {
      "display_name": "AKShare (东财封装)",
      "priority": 3,
      "collector_class": "src.datacollect.collectors.akshare_collector.AkshareCollector",
      "package": "akshare",
      "needs_token": false,
      "rate_domain": "eastmoney",
      "rate": 0.15,
      "burst": 3,
      "max_concurrent": 2,
      "capabilities": ["stock_list", "daily_kline", "index_daily", "financial", "etf", "sector", "cb", "realtime", "forex", "futures_basis"],
      "history_depth_years": 10,
      "supports_realtime": true,
      "note": "全品类, 底层调用东财API, 限流严格(~7秒/次)"
    },
    "tushare": {
      "display_name": "Tushare Pro",
      "priority": 4,
      "collector_class": "src.datacollect.collectors.tushare_collector.TushareCollector",
      "package": "tushare",
      "needs_token": true,
      "token_env": "TUSHARE_TOKEN",
      "rate_domain": "tushare",
      "rate": 0.8,
      "burst": 5,
      "max_concurrent": 5,
      "capabilities": ["stock_list", "daily_kline", "index_daily", "financial", "etf", "cb", "realtime"],
      "history_depth_years": 10,
      "supports_realtime": true,
      "note": "数据最全, 需积分, 基础120积分注册即得"
    },
    "adata": {
      "display_name": "AData (多源融合)",
      "priority": 5,
      "collector_class": "src.datacollect.collectors.adata_collector.AdataCollector",
      "package": "adata",
      "needs_token": false,
      "rate_domain": "adata",
      "rate": 0.5,
      "burst": 5,
      "max_concurrent": 3,
      "capabilities": ["stock_list", "daily_kline", "sector", "cb", "realtime"],
      "history_depth_years": 10,
      "supports_realtime": true,
      "note": "内置多源切换和动态代理"
    },
    "pytdx": {
      "display_name": "PyTDX (通达信协议)",
      "priority": 6,
      "collector_class": "src.datacollect.collectors.pytdx_collector.PytdxCollector",
      "package": "pytdx",
      "needs_token": false,
      "rate_domain": "pytdx",
      "rate": 1.0,
      "burst": 5,
      "max_concurrent": 5,
      "capabilities": ["stock_list", "daily_kline", "minute_kline", "realtime"],
      "history_depth_years": 10,
      "supports_realtime": true,
      "note": "直连通达信行情服务器, 支持Tick数据"
    },
    "eastmoney": {
      "display_name": "东方财富 HTTP (直连)",
      "priority": 7,
      "collector_class": "src.datacollect.collectors.eastmoney_collector.EastmoneyCollector",
      "package": null,
      "needs_token": false,
      "rate_domain": "eastmoney",
      "rate": 0.1,
      "burst": 2,
      "max_concurrent": 3,
      "capabilities": ["stock_list", "daily_kline", "index_daily", "sector", "cb", "etf", "financial", "realtime"],
      "history_depth_years": 10,
      "supports_realtime": true,
      "note": "直接调用东财HTTP API, 使用SmartHttpClient反爬, 限流最严格"
    },
    "yfinance": {
      "display_name": "Yahoo Finance (yfinance)",
      "priority": 1,
      "collector_class": "src.datacollect.collectors.yfinance_collector.YfinanceCollector",
      "package": "yfinance",
      "needs_token": false,
      "rate_domain": "yfinance",
      "rate": 0.5,
      "burst": 10,
      "max_concurrent": 10,
      "capabilities": ["global_index", "vix", "gold", "crude_oil", "forex", "bond_yield", "ftse_a50"],
      "history_depth_years": 30,
      "supports_realtime": false,
      "tier": 2,
      "note": "全球市场主力源, 覆盖指数/商品/外汇/债券, 免费无限"
    },
    "sina_global": {
      "display_name": "新浪财经全球 (HTTP)",
      "priority": 2,
      "collector_class": "src.datacollect.collectors.sina_global_collector.SinaGlobalCollector",
      "package": null,
      "needs_token": false,
      "rate_domain": "sina",
      "rate": 0.2,
      "burst": 3,
      "max_concurrent": 3,
      "capabilities": ["global_index", "forex", "gold", "crude_oil", "ftse_a50"],
      "history_depth_years": 0,
      "supports_realtime": true,
      "tier": 2,
      "note": "新浪全球行情 HTTP API, 实时快照, 无历史数据"
    },
    "rss_aggregator": {
      "display_name": "财经新闻 RSS 聚合",
      "priority": 3,
      "collector_class": "src.datacollect.collectors.news_rss_collector.NewsRssCollector",
      "package": "feedparser",
      "needs_token": false,
      "rate_domain": "rss",
      "rate": 1.0,
      "burst": 5,
      "max_concurrent": 5,
      "capabilities": ["financial_news"],
      "history_depth_years": 0,
      "supports_realtime": false,
      "tier": 2,
      "note": "RSS 聚合财联社/东财/华尔街见闻等财经新闻"
    }
  },
  "fallback_chains": {
    "stock_list":    ["xtquant", "baostock", "akshare", "adata", "tushare"],
    "daily_kline":   ["xtquant", "baostock", "akshare", "adata", "tushare", "pytdx"],
    "minute_kline":  ["xtquant", "pytdx", "baostock"],
    "index_daily":   ["xtquant", "baostock", "akshare", "tushare", "eastmoney"],
    "financial":     ["xtquant", "baostock", "akshare", "tushare", "eastmoney"],
    "etf":           ["xtquant", "akshare", "tushare", "adata", "eastmoney"],
    "sector":        ["akshare", "adata", "eastmoney"],
    "cb":            ["xtquant", "akshare", "tushare", "eastmoney", "adata"],
    "realtime":      ["xtquant", "akshare", "adata", "pytdx", "eastmoney"],
    "tick":          ["xtquant", "pytdx"],
    "global_index":  ["yfinance", "sina_global"],
    "vix":           ["yfinance", "sina_global"],
    "gold":          ["yfinance", "sina_global"],
    "crude_oil":     ["yfinance", "sina_global"],
    "forex":         ["yfinance", "sina_global", "akshare"],
    "bond_yield":    ["yfinance"],
    "ftse_a50":      ["yfinance", "sina_global"],
    "futures_basis": ["akshare"],
    "financial_news":["rss_aggregator"]
  }
}
