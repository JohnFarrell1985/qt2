{
  "mcpServers": {
    "context7": {
      "url": "https://mcp.context7.com/mcp",
      "headers": {
        "CONTEXT7_API_KEY": "YOUR_CONTEXT7_API_KEY"
      }
    },
    "postgres": {
      "command": "npx",
      "args": [
        "-y",
        "@sarmadparvez/postgresql-mcp",
        "postgresql://user:password@localhost:5432/qt_quant?mode=readonly"
      ]
    },
    "sequential-thinking": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-sequential-thinking"
      ]
    }
  }
}
